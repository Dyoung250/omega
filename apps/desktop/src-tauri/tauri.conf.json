{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FORGIA",
  "version": "0.1.0",
  "identifier": "com.forgia.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FORGIA — Editor 3D",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 800,
        "center": true,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability for FORGIA",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:default",
            "shell:allow-execute",
            "shell:allow-open",
            "updater:default",
            "updater:allow-check",
            "updater:allow-download",
            "updater:allow-install"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://forgia.app/api/updater/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxQjY0QzI0NjY4RTU5MjIKUldUbCtjblV1bG9FSmJLb0s0c1B3QW9tb0ZaK0F4a2JYb0N6MkRjek1qbVhDdHJKZERGVFlUaQo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
